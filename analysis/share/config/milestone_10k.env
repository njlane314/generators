# First production milestone: generate 10,000 proposal events per local sample.
config_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
events="${events:-10000}"
plan="${plan:-${config_dir}/sample_matrix.tsv}"
produce_samples="${produce_samples:-1}"
generator_filter="${generator_filter:-NuWro,GiBUU}"
beam_energy_min_gev="${beam_energy_min_gev:-0}"
beam_energy_max_gev="${beam_energy_max_gev:-10}"

# The first milestone is generation-only. GENIE production is grid-driven by
# design. Set run_analysis=1 after local NuWro/GiBUU and grid GENIE flat files
# exist to build the matrix and yield tables.
run_analysis="${run_analysis:-0}"
run_plots="${run_plots:-0}"
analysis_energy_min_gev="${analysis_energy_min_gev:-${beam_energy_min_gev}}"
analysis_energy_max_gev="${analysis_energy_max_gev:-${beam_energy_max_gev}}"

matrix_dir="${matrix_dir:-analysis/output/milestone_10k/matrix}"
yield_dir="${yield_dir:-analysis/output/milestone_10k/expected_event_yields}"
